{
  "expo": {
    "name": "Pic Shuffle",
    "slug": "pic-shuffle",
    "scheme": "picshuffle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF4FA"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yacoobali.puzzle",
      "icon": "./assets/icon/icon-ios.png"
    },
    "android": {
      "package": "com.yacoobali.puzzle",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.yacoobali.puzzle",
      "icon": "./assets/icon/icon-android.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon/icon-android.png",
        "backgroundColor": "#FFF4FA"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "defaultChannel": "play-reminders"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Pic Shuffle needs access to your photos so you can turn one into a puzzle."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a99bb589-c56a-4f0d-8751-c5d9a2334f24"
      }
    }
  }
}
